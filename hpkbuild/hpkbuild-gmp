#!/bin/bash
# -----------------------------------------------------------------------------
# gmp HPKBUILD - 为鸿蒙交叉编译适配 (TexLive / MPFR 依赖项)
# -----------------------------------------------------------------------------
pkgname=gmp
pkgver=6.3.0
pkgdesc="GNU Multiple Precision Arithmetic Library"
url="https://gmplib.org/"
archs=("arm64-v8a")
license=("LGPL-3.0-or-later" "GPL-2.0-or-later")
depends=()
makedepends=("make" "m4")

# 使用阿里云镜像，国内访问稳定
source="https://mirrors.aliyun.com/gnu/gmp/gmp-${pkgver}.tar.xz"
autounpack=true
downloadpackage=true
buildtools="configure"

builddir=gmp-${pkgver}
packagename=gmp-${pkgver}.tar.xz

# -----------------------------------------------------------------------------
# prepare()
# -----------------------------------------------------------------------------
prepare() {
    echo "[gmp] Preparing source..."
    
    # 自动重命名解压目录
    if [ ! -d "$builddir" ]; then
        local decoded_dir=$(ls -d gmp* 2>/dev/null | grep -v "\.tar" | head -n 1)
        [ -n "$decoded_dir" ] && mv "$decoded_dir" "$builddir"
    fi
    
    # patch config.sub 让它识别 ohos
    # 注意：GMP 用的是 configfsf.sub 文件名（FSF 版本）
    for cs in "$builddir/configfsf.sub" "$builddir/config.sub"; do
        if [ -f "$cs" ] && ! grep -q "ohos" "$cs"; then
            echo "[gmp] Patching $cs to recognize 'ohos'..."
            sed -i 's/-musl\*/-musl* | -ohos*/g' "$cs"
            chmod +x "$cs"
        fi
    done
    
    mkdir -p "$builddir/build-$ARCH"
    echo "[gmp] Prepare completed. ARCH=$ARCH" >> "$buildlog"
}

# ============================================================================
# build()
# ============================================================================
build() {
    local build_dir="$builddir/build-$ARCH"
    local install_dir="${LYCIUM_ROOT}/usr/${pkgname}/${ARCH}"
    
    echo "[gmp] Building for $ARCH..." | tee -a "$buildlog"
    mkdir -p "$install_dir"
    cd "$build_dir" || return 1
    
    local target="aarch64-linux-ohos"
    local sysroot="$OHOS_SDK/native/sysroot"
    
    # 注入鸿蒙工具链
    export CC="$OHOS_SDK/native/llvm/bin/clang --target=$target --sysroot=$sysroot"
    export CXX="$OHOS_SDK/native/llvm/bin/clang++ --target=$target --sysroot=$sysroot"
    export AR="$OHOS_SDK/native/llvm/bin/llvm-ar"
    export RANLIB="$OHOS_SDK/native/llvm/bin/llvm-ranlib"
    export STRIP="$OHOS_SDK/native/llvm/bin/llvm-strip"
    export CFLAGS="-fPIC -O2"
    export CXXFLAGS="-fPIC -O2"
    export LDFLAGS="--target=$target --sysroot=$sysroot"
    
    # 关键参数说明：
    # 1. --host=aarch64-linux-gnu     绕过 config.sub 不识别 ohos 的问题
    # 2. ABI=64                        指定为 64 位 aarch64
    # 3. --disable-assembly            关闭手写汇编，避免与鸿蒙 musl libc 的兼容性问题
    #                                  (GMP 的 aarch64 汇编代码假设了 glibc 的某些行为)
    # 4. --enable-cxx                  启用 C++ 接口（mpfr 不强制需要，但保险起见）
    # 5. --enable-shared --enable-static  同时生成动态和静态库
    ../configure \
        --host=aarch64-linux-gnu \
        --prefix="$install_dir" \
        --enable-shared \
        --enable-static \
        --enable-cxx \
        --disable-assembly \
        ABI=64 \
        >> "$buildlog" 2>&1
    
    local ret=$?
    if [ $ret -ne 0 ]; then
        echo "[gmp] ERROR: configure failed" >> "$buildlog"
        cat config.log >> "$buildlog" 2>&1
        cd "$OLDPWD"
        unset CC CXX AR RANLIB STRIP CFLAGS CXXFLAGS LDFLAGS
        return $ret
    fi
    
    make -j$(nproc) >> "$buildlog" 2>&1
    ret=$?
    
    cd "$OLDPWD"
    unset CC CXX AR RANLIB STRIP CFLAGS CXXFLAGS LDFLAGS
    return $ret
}

# ============================================================================
# package()
# ============================================================================
package() {
    local build_dir="$builddir/build-$ARCH"
    local install_dir="${LYCIUM_ROOT}/usr/${pkgname}/${ARCH}"
    
    echo "[gmp] Installing to $install_dir..." >> "$buildlog"
    cd "$build_dir" || return 1
    
    make install >> "$buildlog" 2>&1
    local ret=$?
    
    cd "$OLDPWD"
    
    # 验证关键产物
    if [ ! -f "$install_dir/lib/libgmp.so" ] && \
       [ ! -f "$install_dir/lib/libgmp.a" ]; then
        echo "[gmp] ERROR: libgmp not installed!" >> "$buildlog"
        return 1
    fi
    
    if [ ! -f "$install_dir/include/gmp.h" ]; then
        echo "[gmp] ERROR: gmp.h not found!" >> "$buildlog"
        return 1
    fi
    
    echo "[gmp] Installation completed." >> "$buildlog"
    return $ret
}

# ============================================================================
# check()
# ============================================================================
check() {
    echo "[gmp] Check skipped for cross-compilation"
    return 0
}

# ============================================================================
# cleanbuild()
# ============================================================================
cleanbuild() {
    rm -rf "$builddir"
}