pkgname=freetype2
pkgver=VER-2-13-0
pkgrel=0
pkgdesc="FreeType is a freely available software library to render fonts."
url="https://freetype.org"
archs=("arm64-v8a")
license=("GPL FTL")
depends=("zlib_1_3_1" "bzip2_1_0_8" "brotli" "libpng")
makedepends=()
# 官方下载地址https://sourceforge.net/projects/freetype/files/$pkgname/$pkgver/freetype-$pkgver.tar.xz受网络影响可能存在下载失败的情况，现使用gitee镜像可以与官方仓库保持同步
source="https://gitee.com/lycium_pkg_mirror/${pkgname:0:8}/repository/archive/$pkgver.zip"

autounpack=true
downloadpackage=true

builddir=${pkgname:0:8}-${pkgver}
packagename=$builddir.zip

testdir=

prepare() {
    testdir=`pwd`/$builddir/$ARCH-build/freetype-cmake-testbuild
    rm -rf $testdir
    mkdir -p $testdir
}

build() {
    cd $builddir
    # ── Brotli 路径（从 LYCIUM_ROOT 里找已编译好的 brotli）──────────────────
    BROTLI_ROOT=$LYCIUM_ROOT/usr/brotli/$ARCH
    BROTLI_INC=$BROTLI_ROOT/include
    BROTLI_DEC_LIB=$BROTLI_ROOT/lib/libbrotlidec.a
    BROTLI_COMMON_LIB=$BROTLI_ROOT/lib/libbrotlicommon.a
    # ── 其他依赖路径 ──────────────────────────────────────────────────────────
    ZLIB_ROOT=$LYCIUM_ROOT/usr/zlib_1_3_1/$ARCH
    BZIP2_ROOT=$LYCIUM_ROOT/usr/bzip2_1_0_8/$ARCH
    PNG_ROOT=$LYCIUM_ROOT/usr/libpng/$ARCH
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DOHOS_ARCH=$ARCH \
        \
        `# ── Brotli：从禁用改为启用，并显式传入路径 ──` \
        -DFT_DISABLE_BROTLI=OFF \
        -DBROTLI_FOUND=TRUE \
        -DBROTLI_INCLUDE_DIRS="$BROTLI_INC" \
        -DBROTLIDEC_LIBRARIES="$BROTLI_DEC_LIB" \
        -DBROTLICOMMON_LIBRARIES="$BROTLI_COMMON_LIB" \
        \
        `# ── 其他依赖：按需开启（原来全部禁用，现在按实际情况打开）──` \
        -DFT_DISABLE_BZIP2=OFF \
        -DBZIP2_INCLUDE_DIR="$BZIP2_ROOT/include" \
        -DBZIP2_LIBRARIES="$BZIP2_ROOT/lib/libbz2.a" \
        \
        -DFT_DISABLE_PNG=OFF \
        -DPNG_PNG_INCLUDE_DIR="$PNG_ROOT/include" \
        -DPNG_LIBRARY="$PNG_ROOT/lib/libpng.a" \
        \
        -DFT_DISABLE_ZLIB=OFF \
        -DZLIB_INCLUDE_DIR="$ZLIB_ROOT/include" \
        -DZLIB_LIBRARY="$ZLIB_ROOT/lib/libz.a" \
        \
        -DFT_DISABLE_HARFBUZZ=ON \
        -DFT_ENABLE_ERROR_STRINGS=ON \
        \
        -B$testdir/ftb \
        -S./ \
        -L > `pwd`/$ARCH-build/build.log 2>&1
    make -j4 -C $testdir/ftb >> `pwd`/$ARCH-build/build.log 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd "$builddir"
    make -C $testdir/ftb install >> `pwd`/$ARCH-build/build.log 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

# 清理环境
cleanbuild(){
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
}
